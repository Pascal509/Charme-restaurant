# ====================
# CHARME - Environment Template
# ====================
# Copy this file to .env.local and fill in the values
# NEVER commit real secrets - use .env.local for local development

# Application Core
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
BASE_CURRENCY=NGN

# Catalog Mode: 'static' for demos (no database), 'prisma' for production
CATALOG_READ_SOURCE=static

# Database (required only when CATALOG_READ_SOURCE=prisma)
# DATABASE_URL=postgresql://user:password@localhost:5432/charme
# DIRECT_URL=postgresql://user:password@localhost:5432/charme

# Authentication - Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Payment Provider - Flutterwave (optional)
# DEFAULT_PAYMENT_PROVIDER=FLUTTERWAVE
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_xxxx
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_xxxx
# FLUTTERWAVE_WEBHOOK_SECRET=xxxx
# FLUTTERWAVE_REDIRECT_URL=http://localhost:3000/en/ng/checkout/redirect

# Payment Provider - Paystack (optional)
# PAYSTACK_PUBLIC_KEY=pk_test_xxxx
# PAYSTACK_SECRET_KEY=sk_test_xxxx
# PAYSTACK_REDIRECT_URL=http://localhost:3000/en/ng/checkout/redirect

# Redis / Real-time (optional)
# REDIS_ENABLED=1
# REDIS_URL=redis://localhost:6379

# FX / Pricing (optional)
FX_RATE_TTL_SECONDS=3600
FX_SPREAD_BPS=50

# Demo Helpers (optional)
SHOW_DEMO_LOGS=0
SKIP_ENV_VALIDATION=0
